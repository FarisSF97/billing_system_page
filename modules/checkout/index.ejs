            <a href="/account" class="auth-btn user-btn">
              <i class="fas fa-user"></i> <%= user.name %>
            </a>
          <% } else { %>
            <a href="/login" class="auth-btn login-btn">Login</a>
          <% } %>
        </div>
      </div>

