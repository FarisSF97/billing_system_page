          <div class="payment-method"><img src="/assets/img/shopee_logo.png" alt=""></div>
          <div class="payment-method"><img src="/assets/img/dana_logo.png" alt=""></div>
          <div class="payment-method"><img src="/assets/img/linkaja_logo.png" alt=""></div>
          <div class="payment-method"><img src="/assets/img/qris_logo.png" alt=""></div>
