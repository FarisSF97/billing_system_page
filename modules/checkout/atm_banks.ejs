<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pilih Bank Transfer</title>
    <script src="https://kit.fontawesome.com/bba4075092.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <style>
      .banks-container {
        max-width: 800px;
        margin: 50px auto;
        padding: 40px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      }
      
      .banks-header {
        text-align: center;
        margin-bottom: 40px;
      }
      
      .banks-title {
        font-size: 28px;
        color: #2c3e50;
        margin-bottom: 10px;
        font-weight: 600;
      }
      
      .banks-subtitle {
        font-size: 16px;
        color: #7f8c8d;
      }
      
      .banks-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
      }
      
      .bank-card {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 24px;
        cursor: pointer;
        transition: all 0.3s ease;
        background: white;
      }
      
      .bank-card:hover {
        border-color: #3498db;
        box-shadow: 0 5px 15px rgba(52, 152, 219, 0.1);
        transform: translateY(-2px);
      }
      
      .bank-header {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
      }
      
      .bank-icon {
        width: 50px;
        height: 50px;
        background: #f8f9fa;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 15px;
        font-size: 24px;
        color: #2c3e50;
      }
      
      .bank-name {
        font-size: 18px;
        font-weight: 600;
        color: #2c3e50;
      }
      
      .bank-details {
        margin-top: 15px;
        padding-top: 15px;
        border-top: 1px solid #e9ecef;
      }
      
      .detail-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
        font-size: 14px;
      }
      
      .detail-label {
        color: #7f8c8d;
        font-weight: 500;
      }
      
      .detail-value {
        color: #2c3e50;
        font-weight: 600;
      }
      
      .back-btn {
        background: transparent;
        color: #7f8c8d;
        padding: 12px 24px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        font-size: 14px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: all 0.3s ease;
      }
      
      .back-btn:hover {
        border-color: #bdc3c7;
        color: #2c3e50;
      }
      
      /* Modal Styles */
      .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
      }
      
      .modal-overlay.active {
        display: flex;
      }
      
      .modal {
        background: white;
        border-radius: 12px;
        max-width: 500px;
        width: 90%;
        max-height: 80vh;
        overflow-y: auto;
        position: relative;
      }
      
      .modal-header {
        padding: 24px;
        border-bottom: 1px solid #e9ecef;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      
      .modal-title {
        font-size: 20px;
        font-weight: 600;
        color: #2c3e50;
      }
      
      .close-btn {
        background: none;
        border: none;
        font-size: 24px;
        color: #7f8c8d;
        cursor: pointer;
        padding: 0;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        transition: background 0.3s ease;
      }
      
      .close-btn:hover {
        background: #f8f9fa;
      }
      
      .modal-body {
        padding: 24px;
      }
      
      .instruction-list {
        list-style: none;
        padding: 0;
        margin: 0 0 20px 0;
      }
      
      .instruction-list li {
        padding: 12px 0;
        border-bottom: 1px solid #f8f9fa;
        display: flex;
        align-items: flex-start;
      }
      
      .instruction-list li:last-child {
        border-bottom: none;
      }
      
      .step-number {
        background: #3498db;
        color: white;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 600;
        margin-right: 12px;
        flex-shrink: 0;
        margin-top: 2px;
      }
      
      .step-text {
        flex: 1;
        color: #2c3e50;
        line-height: 1.5;
      }
      
      .confirmation-note {
        background: #fff3cd;
        border: 1px solid #ffeaa7;
        border-radius: 8px;
        padding: 16px;
        margin-top: 20px;
      }
      
      .confirmation-note-title {
        font-weight: 600;
        color: #856404;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
      }
      
      .confirmation-note-title i {
        margin-right: 8px;
      }
      
      .confirmation-note-text {
        color: #856404;
        font-size: 14px;
        line-height: 1.5;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="banks-container">
        <div class="banks-header">
          <h1 class="banks-title">Pilih Bank Transfer</h1>
          <p class="banks-subtitle">Silakan pilih bank tujuan transfer</p>
        </div>
        
        <div class="banks-grid">
          <div class="bank-card" data-bank="BRI" data-account="1234567890" data-owner="PT. Digital Indonesia">
            <div class="bank-header">
              <div class="bank-icon">
                <i class="fas fa-university"></i>
              </div>
              <div class="bank-name">Bank BRI</div>
            </div>
            <div class="bank-details">
              <div class="detail-row">
                <span class="detail-label">No. Rekening:</span>
                <span class="detail-value">1234567890</span>
              </div>
              <div class="detail-row">
                <span class="detail-label">Atas Nama:</span>
                <span class="detail-value">PT. Digital Indonesia</span>
              </div>
            </div>
          </div>
          
          <div class="bank-card" data-bank="BNI" data-account="0987654321" data-owner="PT. Digital Indonesia">
            <div class="bank-header">
              <div class="bank-icon">
                <i class="fas fa-university"></i>
              </div>
              <div class="bank-name">Bank BNI</div>
            </div>
            <div class="bank-details">
              <div class="detail-row">
                <span class="detail-label">No. Rekening:</span>
                <span class="detail-value">0987654321</span>
              </div>
              <div class="detail-row">
                <span class="detail-label">Atas Nama:</span>
                <span class="detail-value">PT. Digital Indonesia</span>
              </div>
            </div>
          </div>
          
          <div class="bank-card" data-bank="BSI" data-account="1122334455" data-owner="PT. Digital Indonesia">
            <div class="bank-header">
              <div class="bank-icon">
                <i class="fas fa-university"></i>
              </div>
              <div class="bank-name">Bank BSI</div>
            </div>
            <div class="bank-details">
              <div class="detail-row">
                <span class="detail-label">No. Rekening:</span>
                <span class="detail-value">1122334455</span>
              </div>
              <div class="detail-row">
                <span class="detail-label">Atas Nama:</span>
                <span class="detail-value">PT. Digital Indonesia</span>
              </div>
            </div>
          </div>
          
          <div class="bank-card" data-bank="BCA" data-account="5544332211" data-owner="PT. Digital Indonesia">
            <div class="bank-header">
              <div class="bank-icon">
                <i class="fas fa-university"></i>
              </div>
              <div class="bank-name">Bank BCA</div>
            </div>
            <div class="bank-details">
              <div class="detail-row">
                <span class="detail-label">No. Rekening:</span>
                <span class="detail-value">5544332211</span>
              </div>
              <div class="detail-row">
                <span class="detail-label">Atas Nama:</span>
                <span class="detail-value">PT. Digital Indonesia</span>
              </div>
            </div>
          </div>
          
          <div class="bank-card" data-bank="Mandiri" data-account="9988776655" data-owner="PT. Digital Indonesia">
            <div class="bank-header">
              <div class="bank-icon">
                <i class="fas fa-university"></i>
              </div>
              <div class="bank-name">Bank Mandiri</div>
            </div>
            <div class="bank-details">
              <div class="detail-row">
                <span class="detail-label">No. Rekening:</span>
                <span class="detail-value">9988776655</span>
              </div>
              <div class="detail-row">
                <span class="detail-label">Atas Nama:</span>
                <span class="detail-value">PT. Digital Indonesia</span>
              </div>
            </div>
          </div>
        </div>
        
        <a href="/atm_email" class="back-btn">Kembali</a>
      </div>
    </div>
    
    <!-- Payment Instructions Modal -->
    <div class="modal-overlay" id="instructionModal">
      <div class="modal">
        <div class="modal-header">
          <h3 class="modal-title" id="modalBankName">Instruksi Pembayaran</h3>
          <button class="close-btn" id="closeModal">&times;</button>
        </div>
        <div class="modal-body">
          <ul class="instruction-list">
            <li>
              <div class="step-number">1</div>
              <div class="step-text">Pergi ke ATM terdekat atau buka aplikasi m-banking Anda</div>
            </li>
            <li>
              <div class="step-number">2</div>
              <div class="step-text">Pilih menu "Transfer" atau "Transfer Antar Bank"</div>
            </li>
            <li>
              <div class="step-number">3</div>
              <div class="step-text">Masukkan nomor rekening tujuan yang tertera</div>
            </li>
            <li>
              <div class="step-number">4</div>
              <div class="step-text">Masukkan jumlah pembayaran sesuai dengan total pesanan</div>
            </li>
            <li>
              <div class="step-number">5</div>
              <div class="step-text">Konfirmasi detail transfer dan selesaikan pembayaran</div>
            </li>
            <li>
              <div class="step-number">6</div>
              <div class="step-text">Simpan bukti transfer untuk konfirmasi</div>
            </li>
          </ul>
          
          <div class="confirmation-note">
            <div class="confirmation-note-title">
              <i class="fas fa-info-circle"></i>
              Penting!
            </div>
            <div class="confirmation-note-text">
              Setelah pembayaran berhasil, silakan konfirmasi ke CS kami dengan menyertakan nomor invoice agar kami dapat mengirim nomor seri Anda.
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <script>
      const bankCards = document.querySelectorAll('.bank-card');
      const modal = document.getElementById('instructionModal');
      const closeModalBtn = document.getElementById('closeModal');
      const modalBankName = document.getElementById('modalBankName');
      
      bankCards.forEach(card => {
        card.addEventListener('click', () => {
          const bankName = card.dataset.bank;
          const accountNumber = card.dataset.account;
          const ownerName = card.dataset.owner;
          
          // Update modal title with bank name
          modalBankName.textContent = `Instruksi Pembayaran - ${bankName}`;
          
          // Show modal
          modal.classList.add('active');
          
          // Store bank info for potential future use
          sessionStorage.setItem('selectedBank', bankName);
          sessionStorage.setItem('bankAccount', accountNumber);
          sessionStorage.setItem('bankOwner', ownerName);
        });
      });
      
      // Close modal when clicking close button
      closeModalBtn.addEventListener('click', () => {
        modal.classList.remove('active');
      });
      
      // Close modal when clicking outside
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.remove('active');
        }
      });
      
      // Prevent modal from closing when clicking inside
      const modalContent = document.querySelector('.modal');
      modalContent.addEventListener('click', (e) => {
        e.stopPropagation();
      });
    </script>
  </body>
</html>
