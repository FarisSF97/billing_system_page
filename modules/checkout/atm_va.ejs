<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ATM Bersama Virtual Account</title>
    <script src="https://kit.fontawesome.com/bba4075092.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <style>
      .va-container {
        max-width: 600px;
        margin: 50px auto;
        padding: 40px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      }
      
      .va-header {
        text-align: center;
        margin-bottom: 40px;
      }
      
      .va-icon {
        width: 80px;
        height: 80px;
        background: #e74c3c;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
      }
      
      .va-icon i {
        color: white;
        font-size: 40px;
      }
      
      .va-title {
        font-size: 24px;
        color: #2c3e50;
        margin-bottom: 10px;
        font-weight: 600;
      }
      
      .va-subtitle {
        font-size: 16px;
        color: #7f8c8d;
        margin-bottom: 30px;
      }
      
      .va-section {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 24px;
        margin-bottom: 24px;
      }
      
      .va-section-title {
        font-size: 18px;
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
      }
      
      .va-section-title i {
        margin-right: 8px;
        color: #e74c3c;
      }
      
      .va-number {
        background: white;
        border: 2px solid #e74c3c;
        border-radius: 8px;
        padding: 16px;
        text-align: center;
        margin-bottom: 16px;
        position: relative;
      }
      
      .va-number-label {
        font-size: 12px;
        color: #7f8c8d;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 1px;
      }
      
      .va-number-value {
        font-size: 24px;
        font-weight: 700;
        color: #2c3e50;
        letter-spacing: 2px;
        font-family: 'Courier New', monospace;
      }
      
      .copy-btn {
        background: #e74c3c;
        color: white;
        border: none;
        border-radius: 6px;
        padding: 8px 16px;
        font-size: 14px;
        cursor: pointer;
        margin-top: 12px;
        transition: background 0.3s ease;
      }
      
      .copy-btn:hover {
        background: #c0392b;
      }
      
      .copy-btn.copied {
        background: #27ae60;
      }
      
      .timer-section {
        background: #fff3cd;
        border: 1px solid #ffeaa7;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 24px;
        text-align: center;
      }
      
      .timer-title {
        font-size: 16px;
        font-weight: 600;
        color: #856404;
        margin-bottom: 8px;
      }
      
      .timer-display {
        font-size: 32px;
        font-weight: 700;
        color: #e74c3c;
        font-family: 'Courier New', monospace;
      }
      
      .timer-expired {
        color: #e74c3c;
        font-size: 18px;
        font-weight: 600;
      }
      
      .instructions {
        background: #e8f4fd;
        border: 1px solid #bee5eb;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 24px;
      }
      
      .instructions-title {
        font-size: 16px;
        font-weight: 600;
        color: #0c5460;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
      }
      
      .instructions-title i {
        margin-right: 8px;
      }
      
      .instruction-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      
      .instruction-list li {
        padding: 8px 0;
        border-bottom: 1px solid #d1ecf1;
        display: flex;
        align-items: flex-start;
        font-size: 14px;
        color: #2c3e50;
      }
      
      .instruction-list li:last-child {
        border-bottom: none;
      }
      
      .step-number {
        background: #0c5460;
        color: white;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 600;
        margin-right: 12px;
        flex-shrink: 0;
        margin-top: 2px;
      }
      
      .payment-info {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 24px;
      }
      
      .info-item {
        background: #f8f9fa;
        padding: 16px;
        border-radius: 8px;
        border-left: 4px solid #e74c3c;
      }
      
      .info-label {
        font-size: 12px;
        color: #7f8c8d;
        margin-bottom: 4px;
        text-transform: uppercase;
      }
      
      .info-value {
        font-size: 16px;
        font-weight: 600;
        color: #2c3e50;
      }
      
      .back-btn {
        background: transparent;
        color: #7f8c8d;
        padding: 12px 24px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        font-size: 14px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: all 0.3s ease;
        margin-right: 12px;
      }
      
      .back-btn:hover {
        border-color: #bdc3c7;
        color: #2c3e50;
      }
      
      .check-payment-btn {
        background: #27ae60;
        color: white;
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: background 0.3s ease;
      }
      
      .check-payment-btn:hover {
        background: #219a52;
      }
      
      .action-buttons {
        display: flex;
        justify-content: space-between;
        margin-top: 24px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="va-container">
        <div class="va-header">
          <div class="va-icon">
            <i class="fas fa-credit-card"></i>
          </div>
          <h1 class="va-title">Virtual Account ATM Bersama</h1>
          <p class="va-subtitle">Silakan lakukan pembayaran menggunakan nomor VA berikut</p>
        </div>
        
        <div class="timer-section">
          <div class="timer-title">Batas Waktu Pembayaran</div>
          <div class="timer-display" id="timer">01:00:00</div>
          <div class="timer-expired" id="expiredMessage" style="display: none;">
            Waktu pembayaran telah habis. Silakan buat pesanan baru.
          </div>
        </div>
        
        <div class="va-section">
          <div class="va-section-title">
            <i class="fas fa-qrcode"></i>
            Nomor Virtual Account
          </div>
          <div class="va-number">
            <div class="va-number-label">Nomor VA ATM Bersama</div>
            <div class="va-number-value" id="vaNumber">8808123456789012</div>
            <button class="copy-btn" id="copyBtn" onclick="copyVANumber()">
              <i class="fas fa-copy"></i> Salin Nomor VA
            </button>
          </div>
        </div>
        
        <div class="payment-info">
          <div class="info-item">
            <div class="info-label">Total Pembayaran</div>
            <div class="info-value" id="totalAmount">Rp 150.000</div>
          </div>
          <div class="info-item">
            <div class="info-label">Nomor Invoice</div>
            <div class="info-value" id="invoiceNumber">INV-20250127-001</div>
          </div>
        </div>
        
        <div class="instructions">
          <div class="instructions-title">
            <i class="fas fa-info-circle"></i>
            Cara Pembayaran
          </div>
          <ul class="instruction-list">
            <li>
              <div class="step-number">1</div>
              <div class="step-text">Pergi ke ATM Bersama terdekat atau buka aplikasi mobile banking yang mendukung ATM Bersama</div>
            </li>
            <li>
              <div class="step-number">2</div>
              <div class="step-text">Pilih menu "Transfer" atau "Pembayaran"</div>
            </li>
            <li>
              <div class="step-number">3</div>
              <div class="step-text">Pilih "Virtual Account" atau "VA Payment"</div>
            </li>
            <li>
              <div class="step-number">4</div>
              <div class="step-text">Masukkan nomor Virtual Account: <strong>8808123456789012</strong></div>
            </li>
            <li>
              <div class="step-number">5</div>
              <div class="step-text">Konfirmasi detail pembayaran dan selesaikan transaksi</div>
            </li>
            <li>
              <div class="step-number">6</div>
              <div class="step-text">Simpan bukti pembayaran sebagai bukti transaksi</div>
            </li>
          </ul>
        </div>
        
        <div class="action-buttons">
          <a href="/atm_email" class="back-btn">Kembali</a>
          <button class="check-payment-btn" id="checkPaymentBtn" onclick="checkPayment()">
            <i class="fas fa-check"></i> Cek Status Pembayaran
          </button>
        </div>
      </div>
    </div>
    
    <script>
      // Generate random VA number and invoice
      function generateVANumber() {
        const prefix = '8808';
        const random = Math.floor(Math.random() * 1000000000000).toString().padStart(12, '0');
        return prefix + random.slice(0, 12);
      }
      
      function generateInvoiceNumber() {
        const now = new Date();
        const dateStr = now.getFullYear().toString() + 
                       (now.getMonth() + 1).toString().padStart(2, '0') + 
                       now.getDate().toString().padStart(2, '0');
        const randomSuffix = Math.floor(Math.random() * 1000).toString().padStart(3, '0');
        const orderNumber = Math.floor(Math.random() * 999) + 1;
        const orderNumberStr = orderNumber.toString().padStart(3, '0');
        return `INV-${dateStr}-${randomSuffix}-${orderNumberStr}`;
      }
      
      // Initialize page data
      const vaNumber = generateVANumber();
      const invoiceNumber = generateInvoiceNumber();
      const customerEmail = sessionStorage.getItem('customerEmail') || 'customer@example.com';
      
      // Get order data from sessionStorage
      const orderData = JSON.parse(sessionStorage.getItem('orderData') || '{}');
      const totalAmount = orderData.totalPrice || 150000; // Default fallback
      
      document.getElementById('vaNumber').textContent = vaNumber;
      document.getElementById('invoiceNumber').textContent = invoiceNumber;
      document.getElementById('totalAmount').textContent = `Rp ${totalAmount.toLocaleString('id-ID')}`;
      
      // Timer functionality (1 hour = 3600 seconds)
      let timeLeft = 3600;
      const timerElement = document.getElementById('timer');
      const expiredMessage = document.getElementById('expiredMessage');
      
      function updateTimer() {
        if (timeLeft <= 0) {
          timerElement.style.display = 'none';
          expiredMessage.style.display = 'block';
          document.getElementById('checkPaymentBtn').disabled = true;
          document.getElementById('checkPaymentBtn').style.background = '#bdc3c7';
          return;
        }
        
        const hours = Math.floor(timeLeft / 3600);
        const minutes = Math.floor((timeLeft % 3600) / 60);
        const seconds = timeLeft % 60;
        
        const display = `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
        timerElement.textContent = display;
        
        timeLeft--;
      }
      
      // Start timer
      setInterval(updateTimer, 1000);
      updateTimer(); // Initial call
      
      // Copy VA number functionality
      function copyVANumber() {
        const vaNumberText = document.getElementById('vaNumber').textContent;
        navigator.clipboard.writeText(vaNumberText).then(() => {
          const copyBtn = document.getElementById('copyBtn');
          copyBtn.classList.add('copied');
          copyBtn.innerHTML = '<i class="fas fa-check"></i> Tersalin!';
          
          setTimeout(() => {
            copyBtn.classList.remove('copied');
            copyBtn.innerHTML = '<i class="fas fa-copy"></i> Salin Nomor VA';
          }, 2000);
        }).catch(err => {
          console.error('Failed to copy VA number:', err);
          alert('Gagal menyalin nomor VA. Silakan salin secara manual.');
        });
      }
      
      // Check payment status (dummy function)
      function checkPayment() {
        const checkBtn = document.getElementById('checkPaymentBtn');
        checkBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Memeriksa...';
        checkBtn.disabled = true;
        
        // Simulate API call to check payment status
        setTimeout(() => {
          // For demo purposes, we'll show a message instead of redirecting
          // In real implementation, this would check actual payment status
          alert('Pembayaran belum diterima. Silakan coba lagi beberapa saat.');
          checkBtn.innerHTML = '<i class="fas fa-check"></i> Cek Status Pembayaran';
          checkBtn.disabled = false;
          
          // Uncomment the line below to redirect to thank you page when payment is confirmed
          // window.location.href = '/thankyou';
        }, 2000);
      }
      
      // Store payment data for potential future use
      sessionStorage.setItem('vaNumber', vaNumber);
      sessionStorage.setItem('invoiceNumber', invoiceNumber);
      sessionStorage.setItem('paymentMethod', 'ATM Bersama VA');
    </script>
  </body>
</html>
